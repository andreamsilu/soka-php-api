# Application environment
# Common values: local, staging, production
APP_ENV=local

# ---------------------------------------------------------------------------
# Database configuration
# ---------------------------------------------------------------------------
# Full DSN string for PDO.
# For MySQL:
#   mysql:host=HOST;port=PORT;dbname=DBNAME;charset=utf8mb4
DB_DSN=mysql:host=127.0.0.1;port=3306;dbname=tigosportsDB;charset=utf8mb4

# Database credentials
DB_USER=root
DB_PASS=gfmLvsb}qXB4+Ayk

# ---------------------------------------------------------------------------
# API security
# ---------------------------------------------------------------------------
# Shared secret between this PHP API and your Next.js frontend.
# Must match NEXT_PUBLIC_API_SECURITY_KEY (or equivalent) in the frontend.
# Use a long, random string. Example: generated by `openssl rand -hex 32`.
API_SECURITY_KEY=change_me_to_a_strong_random_secret

# ---------------------------------------------------------------------------
# External SMS provider
# ---------------------------------------------------------------------------
# Endpoint for sending OTP SMS messages.
SMS_API_URL=http://188.64.188.232/SOKATRIVIA-API-TEST/index.php/api/sms/post/web

# Security key expected by the external SMS API.
# If omitted, the app will fall back to API_SECURITY_KEY.
SMS_API_SECURITY_KEY=change_me_to_sms_api_secret